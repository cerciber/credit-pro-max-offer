{
  "name": "base",
  "version": "1.0.0",
  "description": "Base para el desarrollo de credito digital",
  "private": true,
  "scripts": {
    "dev": "dotenv -e .env -- sh -c 'next dev -p \"${PORT}\"'",
    "dev:test": "npm run check-all && dotenv -e .env -- sh -c 'NODE_ENV=test next dev -p \"${PORT}\"'",
    "dev:prod": "npx dotenv-cli -e .env.production -- sh -c 'npm run build && NODE_ENV=production next start'",
    "test": "playwright test",
    "test:ui": "playwright test --headed",
    "test:webserver": "USE_WEBSERVER=true playwright test",
    "build": "next build",
    "start": "dotenv -e .env -- sh -c 'next start -p \"${PORT}\"'",
    "export": "next build",
    "deploy": "dotenv -e .env.production -- sh -c 'npm run build && vercel deploy --prod --yes --yes --token \"$VERCEL_TOKEN\"'",
    "lint": "next lint --fix",
    "format": "prettier --write \"src/**/*.ts\" \"app/**/*.ts\" \"app/**/*.tsx\"",
    "check-types": "tsc --noEmit",
    "find-duplicates": "jscpd src/ --ignore \"**/*.spec.ts,\" --reporters html,console --min-tokens 40 --threshold 0",
    "check-all": "npm run lint && npm run check-types"
  },
  "dependencies": {
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.14.0",
    "@mui/material": "^5.14.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/js-cookie": "^3.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mongodb": "^4.0.6",
    "@types/mongoose": "^5.11.96",
    "@vercel/node": "^3.0.0",
    "axios": "^1.11.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "jose": "^6.1.0",
    "js-cookie": "^3.0.5",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.19.0",
    "mongoose": "^8.18.0",
    "next": "^14.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^8.2.0",
    "@typescript-eslint/parser": "^8.2.0",
    "dotenv": "^17.2.2",
    "dotenv-cli": "^10.0.0",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-json": "^3.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.3.3",
    "tsx": "^4.20.5",
    "typescript": "^5.0.0",
    "vercel": "^32.0.0"
  }
}
